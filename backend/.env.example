# App
APP_NAME=ReadEz API
DEBUG=false
ENVIRONMENT=development

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/readez

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session
SESSION_SECRET_KEY=your-random-secret-key-min-32-chars
SESSION_EXPIRE_DAYS=30

# Storage
STORAGE_PATH=./storage

# Dodo Payments - Test
DODO_TEST_API_KEY=
DODO_TEST_WEBHOOK_SECRET=
DODO_TEST_PRO_PRODUCT_ID=
DODO_TEST_PLUS_PRODUCT_ID=

# Dodo Payments - Live
DODO_API_KEY=
DODO_WEBHOOK_SECRET=
